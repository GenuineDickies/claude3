# ---------------------------------------------------------------------
# Laravel 11 / 12 — standard-layout .gitignore
# (public/ is the web server document root)
# ---------------------------------------------------------------------

# Dependencies
/vendor/
/node_modules/
npm-debug.log
yarn-error.log

# Vite build output (standard layout: public/build, public/hot)
/public/build/
/public/hot

# Transition shim — delete once SiteGround docroot points at public/
/index.php

# Environment — NEVER commit .env (contains DB password, API keys)
/.env
/.env.backup
/.env.production
/.env.local
/.env.*.local

# Laravel runtime — storage/ contents are per-environment
/storage/*.key
/storage/pail
/storage/framework/cache/data
/storage/framework/sessions
/storage/framework/testing
/storage/framework/views
/storage/logs

# Laravel config/route/view caches (generated by artisan *:cache)
# These contain resolved .env values and MUST NOT be committed.
/bootstrap/cache/*.php
!/bootstrap/cache/.gitkeep

# Local databases (sqlite — if used for dev)
/database/database.sqlite
/database/database.sqlite-journal
/database/*.sqlite
/database/*.sqlite-journal

# Testing
/.phpunit.cache
/.phpunit.result.cache
/phpunit.xml

# Composer auth tokens
/auth.json

# Homestead / Sail leftovers
/Homestead.json
/Homestead.yaml

# IDE / OS
/.idea
/.vscode
/.fleet
/.nova
/.zed
/.DS_Store
Thumbs.db
desktop.ini

# Project-specific — dev scratch + hosting artifacts
/_design-backup/
/_design-mockup/
/Default.html

# Tooling (restored from prior .gitignore)
/.taskmaster/
/.github/instructions/
